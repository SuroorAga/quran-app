[{"id":1,"ref":"53:1","arabic":"وَٱلنَّجۡمِ إِذَا هَوَىٰ","transliteration":"Waalnnajmi itha hawa","translation":"","notes":""},{"id":2,"ref":"53:2","arabic":"مَا ضَلَّ صَاحِبُكُمۡ وَمَا غَوَىٰ","transliteration":"Ma dalla sahibukum wama ghawa","translation":"","notes":""},{"id":3,"ref":"53:3","arabic":"وَمَا يَنطِقُ عَنِ ٱلۡهَوَىٰٓ","transliteration":"Wama yantiqu AAani alhawa","translation":"","notes":""},{"id":4,"ref":"53:4","arabic":"إِنۡ هُوَ إِلَّا وَحۡيٞ يُوحَىٰ","transliteration":"In huwa illa wahyun yooha","translation":"","notes":""},{"id":5,"ref":"53:5","arabic":"عَلَّمَهُۥ شَدِيدُ ٱلۡقُوَىٰ","transliteration":"AAallamahu shadeedu alquwa","translation":"","notes":""},{"id":6,"ref":"53:6","arabic":"ذُو مِرَّةٖ فَٱسۡتَوَىٰ","transliteration":"Thoo mirratin faistawa","translation":"","notes":""},{"id":7,"ref":"53:7","arabic":"وَهُوَ بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ","transliteration":"Wahuwa bialofuqi alaAAla","translation":"","notes":""},{"id":8,"ref":"53:8","arabic":"ثُمَّ دَنَا فَتَدَلَّىٰ","transliteration":"Thumma dana fatadalla","translation":"","notes":""},{"id":9,"ref":"53:9","arabic":"فَكَانَ قَابَ قَوۡسَيۡنِ أَوۡ أَدۡنَىٰ","transliteration":"Fakana qaba qawsayni aw adna","translation":"","notes":""},{"id":10,"ref":"53:10","arabic":"فَأَوۡحَىٰٓ إِلَىٰ عَبۡدِهِۦ مَآ أَوۡحَىٰ","transliteration":"Faawha ila AAabdihi ma awha","translation":"","notes":""},{"id":11,"ref":"53:11","arabic":"مَا كَذَبَ ٱلۡفُؤَادُ مَا رَأَىٰٓ","transliteration":"Ma kathaba alfuadu ma raa","translation":"","notes":""},{"id":12,"ref":"53:12","arabic":"أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ","transliteration":"Afatumaroonahu AAala ma yara","translation":"","notes":""},{"id":13,"ref":"53:13","arabic":"وَلَقَدۡ رَءَاهُ نَزۡلَةً أُخۡرَىٰ","transliteration":"Walaqad raahu nazlatan okhra","translation":"","notes":""},{"id":14,"ref":"53:14","arabic":"عِندَ سِدۡرَةِ ٱلۡمُنتَهَىٰ","transliteration":"AAinda sidrati almuntaha","translation":"","notes":""},{"id":15,"ref":"53:15","arabic":"عِندَهَا جَنَّةُ ٱلۡمَأۡوَىٰٓ","transliteration":"AAindaha jannatu almawa","translation":"","notes":""},{"id":16,"ref":"53:16","arabic":"إِذۡ يَغۡشَى ٱلسِّدۡرَةَ مَا يَغۡشَىٰ","transliteration":"Ith yaghsha alssidrata ma yaghsha","translation":"","notes":""},{"id":17,"ref":"53:17","arabic":"مَا زَاغَ ٱلۡبَصَرُ وَمَا طَغَىٰ","transliteration":"Ma zagha albasaru wama tagha","translation":"","notes":""},{"id":18,"ref":"53:18","arabic":"لَقَدۡ رَأَىٰ مِنۡ ءَايَٰتِ رَبِّهِ ٱلۡكُبۡرَىٰٓ","transliteration":"Laqad raa min ayati rabbihi alkubra","translation":"","notes":""},{"id":19,"ref":"53:19","arabic":"أَفَرَءَيۡتُمُ ٱللَّـٰتَ وَٱلۡعُزَّىٰ","transliteration":"Afaraaytumu allata waalAAuzza","translation":"","notes":""},{"id":20,"ref":"53:20","arabic":"وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰٓ","transliteration":"Wamanata alththalithata alokhra","translation":"","notes":""},{"id":21,"ref":"53:21","arabic":"أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلۡأُنثَىٰ","transliteration":"Alakumu alththakaru walahu alontha","translation":"","notes":""},{"id":22,"ref":"53:22","arabic":"تِلۡكَ إِذٗا قِسۡمَةٞ ضِيزَىٰٓ","transliteration":"Tilka ithan qismatun deeza","translation":"","notes":""},{"id":23,"ref":"53:23","arabic":"إِنۡ هِيَ إِلَّآ أَسۡمَآءٞ سَمَّيۡتُمُوهَآ أَنتُمۡ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلۡطَٰنٍۚ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهۡوَى ٱلۡأَنفُسُۖ وَلَقَدۡ جَآءَهُم مِّن رَّبِّهِمُ ٱلۡهُدَىٰٓ","transliteration":"In hiya illa asmaon sammaytumooha antum waabaokum ma anzala Allahu biha min sultanin in yattabiAAoona illa alththanna wama tahwa alanfusu walaqad jaahum min rabbihimu alhuda","translation":"","notes":""},{"id":24,"ref":"53:24","arabic":"أَمۡ لِلۡإِنسَٰنِ مَا تَمَنَّىٰ","transliteration":"Am lilinsani ma tamanna","translation":"","notes":""},{"id":25,"ref":"53:25","arabic":"فَلِلَّهِ ٱلۡأٓخِرَةُ وَٱلۡأُولَىٰ","transliteration":"Falillahi alakhiratu waaloola","translation":"","notes":""},{"id":26,"ref":"53:26","arabic":"۞وَكَم مِّن مَّلَكٖ فِي ٱلسَّمَٰوَٰتِ لَا تُغۡنِي شَفَٰعَتُهُمۡ شَيۡـًٔا إِلَّا مِنۢ بَعۡدِ أَن يَأۡذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرۡضَىٰٓ","transliteration":"Wakam min malakin fee alssamawati la tughnee shafaAAatuhum shayan illa min baAAdi an yathana Allahu liman yashao wayarda","translation":"","notes":""},{"id":27,"ref":"53:27","arabic":"إِنَّ ٱلَّذِينَ لَا يُؤۡمِنُونَ بِٱلۡأٓخِرَةِ لَيُسَمُّونَ ٱلۡمَلَـٰٓئِكَةَ تَسۡمِيَةَ ٱلۡأُنثَىٰ","transliteration":"Inna allatheena la yuminoona bialakhirati layusammoona almalaikata tasmiyata alontha","translation":"","notes":""},{"id":28,"ref":"53:28","arabic":"وَمَا لَهُم بِهِۦ مِنۡ عِلۡمٍۖ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّۖ وَإِنَّ ٱلظَّنَّ لَا يُغۡنِي مِنَ ٱلۡحَقِّ شَيۡـٔٗا","transliteration":"Wama lahum bihi min AAilmin in yattabiAAoona illa alththanna wainna alththanna la yughnee mina alhaqqi shayan","translation":"","notes":""},{"id":29,"ref":"53:29","arabic":"فَأَعۡرِضۡ عَن مَّن تَوَلَّىٰ عَن ذِكۡرِنَا وَلَمۡ يُرِدۡ إِلَّا ٱلۡحَيَوٰةَ ٱلدُّنۡيَا","transliteration":"FaaAArid AAan man tawalla AAan thikrina walam yurid illa alhayata alddunya","translation":"","notes":""},{"id":30,"ref":"53:30","arabic":"ذَٰلِكَ مَبۡلَغُهُم مِّنَ ٱلۡعِلۡمِۚ إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعۡلَمُ بِمَنِ ٱهۡتَدَىٰ","transliteration":"Thalika mablaghuhum mina alAAilmi inna rabbaka huwa aAAlamu biman dalla AAan sabeelihi wahuwa aAAlamu bimani ihtada","translation":"","notes":""},{"id":31,"ref":"53:31","arabic":"وَلِلَّهِ مَا فِي ٱلسَّمَٰوَٰتِ وَمَا فِي ٱلۡأَرۡضِ لِيَجۡزِيَ ٱلَّذِينَ أَسَـٰٓـُٔواْ بِمَا عَمِلُواْ وَيَجۡزِيَ ٱلَّذِينَ أَحۡسَنُواْ بِٱلۡحُسۡنَى","transliteration":"Walillahi ma fee alssamawati wama fee alardi liyajziya allatheena asaoo bima AAamiloo wayajziya allatheena ahsanoo bialhusna","translation":"","notes":""},{"id":32,"ref":"53:32","arabic":"ٱلَّذِينَ يَجۡتَنِبُونَ كَبَـٰٓئِرَ ٱلۡإِثۡمِ وَٱلۡفَوَٰحِشَ إِلَّا ٱللَّمَمَۚ إِنَّ رَبَّكَ وَٰسِعُ ٱلۡمَغۡفِرَةِۚ هُوَ أَعۡلَمُ بِكُمۡ إِذۡ أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ وَإِذۡ أَنتُمۡ أَجِنَّةٞ فِي بُطُونِ أُمَّهَٰتِكُمۡۖ فَلَا تُزَكُّوٓاْ أَنفُسَكُمۡۖ هُوَ أَعۡلَمُ بِمَنِ ٱتَّقَىٰٓ","transliteration":"Allatheena yajtaniboona kabaira alithmi waalfawahisha illa allamama inna rabbaka wasiAAu almaghfirati huwa aAAlamu bikum ith anshaakum mina alardi waith antum ajinnatun fee butooni ommahatikum fala tuzakkoo anfusakum huwa aAAlamu bimani ittaqa","translation":"","notes":""},{"id":33,"ref":"53:33","arabic":"أَفَرَءَيۡتَ ٱلَّذِي تَوَلَّىٰ","transliteration":"Afaraayta allathee tawalla","translation":"","notes":""},{"id":34,"ref":"53:34","arabic":"وَأَعۡطَىٰ قَلِيلٗا وَأَكۡدَىٰٓ","transliteration":"WaaAAta qaleelan waakda","translation":"","notes":""},{"id":35,"ref":"53:35","arabic":"أَعِندَهُۥ عِلۡمُ ٱلۡغَيۡبِ فَهُوَ يَرَىٰٓ","transliteration":"aAAindahu AAilmu alghaybi fahuwa yara","translation":"","notes":""},{"id":36,"ref":"53:36","arabic":"أَمۡ لَمۡ يُنَبَّأۡ بِمَا فِي صُحُفِ مُوسَىٰ","transliteration":"Am lam yunabba bima fee suhufi moosa","translation":"","notes":""},{"id":37,"ref":"53:37","arabic":"وَإِبۡرَٰهِيمَ ٱلَّذِي وَفَّىٰٓ","transliteration":"Waibraheema allathee waffa","translation":"","notes":""},{"id":38,"ref":"53:38","arabic":"أَلَّا تَزِرُ وَازِرَةٞ وِزۡرَ أُخۡرَىٰ","transliteration":"Alla taziru waziratun wizra okhra","translation":"","notes":""},{"id":39,"ref":"53:39","arabic":"وَأَن لَّيۡسَ لِلۡإِنسَٰنِ إِلَّا مَا سَعَىٰ","transliteration":"Waan laysa lilinsani illa ma saAAa","translation":"","notes":""},{"id":40,"ref":"53:40","arabic":"وَأَنَّ سَعۡيَهُۥ سَوۡفَ يُرَىٰ","transliteration":"Waanna saAAyahu sawfa yura","translation":"","notes":""},{"id":41,"ref":"53:41","arabic":"ثُمَّ يُجۡزَىٰهُ ٱلۡجَزَآءَ ٱلۡأَوۡفَىٰ","transliteration":"Thumma yujzahu aljazaa alawfa","translation":"","notes":""},{"id":42,"ref":"53:42","arabic":"وَأَنَّ إِلَىٰ رَبِّكَ ٱلۡمُنتَهَىٰ","transliteration":"Waanna ila rabbika almuntaha","translation":"","notes":""},{"id":43,"ref":"53:43","arabic":"وَأَنَّهُۥ هُوَ أَضۡحَكَ وَأَبۡكَىٰ","transliteration":"Waannahu huwa adhaka waabka","translation":"","notes":""},{"id":44,"ref":"53:44","arabic":"وَأَنَّهُۥ هُوَ أَمَاتَ وَأَحۡيَا","transliteration":"Waannahu huwa amata waahya","translation":"","notes":""},{"id":45,"ref":"53:45","arabic":"وَأَنَّهُۥ خَلَقَ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰ","transliteration":"Waannahu khalaqa alzzawjayni alththakara waalontha","translation":"","notes":""},{"id":46,"ref":"53:46","arabic":"مِن نُّطۡفَةٍ إِذَا تُمۡنَىٰ","transliteration":"Min nutfatin itha tumna","translation":"","notes":""},{"id":47,"ref":"53:47","arabic":"وَأَنَّ عَلَيۡهِ ٱلنَّشۡأَةَ ٱلۡأُخۡرَىٰ","transliteration":"Waanna AAalayhi alnnashata alokhra","translation":"","notes":""},{"id":48,"ref":"53:48","arabic":"وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنَىٰ","transliteration":"Waannahu huwa aghna waaqna","translation":"","notes":""},{"id":49,"ref":"53:49","arabic":"وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ","transliteration":"Waannahu huwa rabbu alshshiAAra","translation":"","notes":""},{"id":50,"ref":"53:50","arabic":"وَأَنَّهُۥٓ أَهۡلَكَ عَادًا ٱلۡأُولَىٰ","transliteration":"Waannahu ahlaka AAadan aloola","translation":"","notes":""},{"id":51,"ref":"53:51","arabic":"وَثَمُودَاْ فَمَآ أَبۡقَىٰ","transliteration":"Wathamooda fama abqa","translation":"","notes":""},{"id":52,"ref":"53:52","arabic":"وَقَوۡمَ نُوحٖ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُواْ هُمۡ أَظۡلَمَ وَأَطۡغَىٰ","transliteration":"Waqawma noohin min qablu innahum kanoo hum athlama waatgha","translation":"","notes":""},{"id":53,"ref":"53:53","arabic":"وَٱلۡمُؤۡتَفِكَةَ أَهۡوَىٰ","transliteration":"Waalmutafikata ahwa","translation":"","notes":""},{"id":54,"ref":"53:54","arabic":"فَغَشَّىٰهَا مَا غَشَّىٰ","transliteration":"Faghashshaha ma ghashsha","translation":"","notes":""},{"id":55,"ref":"53:55","arabic":"فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَارَىٰ","transliteration":"Fabiayyi alai rabbika tatamara","translation":"","notes":""},{"id":56,"ref":"53:56","arabic":"هَٰذَا نَذِيرٞ مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰٓ","transliteration":"Hatha natheerun mina alnnuthuri aloola","translation":"","notes":""},{"id":57,"ref":"53:57","arabic":"أَزِفَتِ ٱلۡأٓزِفَةُ","transliteration":"Azifati alazifatu","translation":"","notes":""},{"id":58,"ref":"53:58","arabic":"لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ","transliteration":"Laysa laha min dooni Allahi kashifatun","translation":"","notes":""},{"id":59,"ref":"53:59","arabic":"أَفَمِنۡ هَٰذَا ٱلۡحَدِيثِ تَعۡجَبُونَ","transliteration":"Afamin hatha alhadeethi taAAjaboona","translation":"","notes":""},{"id":60,"ref":"53:60","arabic":"وَتَضۡحَكُونَ وَلَا تَبۡكُونَ","transliteration":"Watadhakoona wala tabkoona","translation":"","notes":""},{"id":61,"ref":"53:61","arabic":"وَأَنتُمۡ سَٰمِدُونَ","transliteration":"Waantum samidoona","translation":"","notes":""},{"id":62,"ref":"53:62","arabic":"فَٱسۡجُدُواْۤ لِلَّهِۤ وَٱعۡبُدُواْ۩","transliteration":"Faosjudoo lillahi waoAAbudoo","translation":"","notes":""}]