[{"id":1,"ref":"86:1","arabic":"وَٱلسَّمَآءِ وَٱلطَّارِقِ","transliteration":"Waalssamai waalttariqi","translation":"","notes":""},{"id":2,"ref":"86:2","arabic":"وَمَآ أَدۡرَىٰكَ مَا ٱلطَّارِقُ","transliteration":"Wama adraka ma alttariqu","translation":"","notes":""},{"id":3,"ref":"86:3","arabic":"ٱلنَّجۡمُ ٱلثَّاقِبُ","transliteration":"Alnnajmu alththaqibu","translation":"","notes":""},{"id":4,"ref":"86:4","arabic":"إِن كُلُّ نَفۡسٖ لَّمَّا عَلَيۡهَا حَافِظٞ","transliteration":"In kullu nafsin lamma AAalayha hafithun","translation":"","notes":""},{"id":5,"ref":"86:5","arabic":"فَلۡيَنظُرِ ٱلۡإِنسَٰنُ مِمَّ خُلِقَ","transliteration":"Falyanthuri alinsanu mimma khuliqa","translation":"","notes":""},{"id":6,"ref":"86:6","arabic":"خُلِقَ مِن مَّآءٖ دَافِقٖ","transliteration":"Khuliqa min main dafiqin","translation":"","notes":""},{"id":7,"ref":"86:7","arabic":"يَخۡرُجُ مِنۢ بَيۡنِ ٱلصُّلۡبِ وَٱلتَّرَآئِبِ","transliteration":"Yakhruju min bayni alssulbi waalttaraibi","translation":"","notes":""},{"id":8,"ref":"86:8","arabic":"إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ","transliteration":"Innahu AAala rajAAihi laqadirun","translation":"","notes":""},{"id":9,"ref":"86:9","arabic":"يَوۡمَ تُبۡلَى ٱلسَّرَآئِرُ","transliteration":"Yawma tubla alssarairu","translation":"","notes":""},{"id":10,"ref":"86:10","arabic":"فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖ","transliteration":"Fama lahu min quwwatin wala nasirin","translation":"","notes":""},{"id":11,"ref":"86:11","arabic":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجۡعِ","transliteration":"Waalssamai thati alrrajAAi","translation":"","notes":""},{"id":12,"ref":"86:12","arabic":"وَٱلۡأَرۡضِ ذَاتِ ٱلصَّدۡعِ","transliteration":"Waalardi thati alssadAAi","translation":"","notes":""},{"id":13,"ref":"86:13","arabic":"إِنَّهُۥ لَقَوۡلٞ فَصۡلٞ","transliteration":"Innahu laqawlun faslun","translation":"","notes":""},{"id":14,"ref":"86:14","arabic":"وَمَا هُوَ بِٱلۡهَزۡلِ","transliteration":"Wama huwa bialhazli","translation":"","notes":""},{"id":15,"ref":"86:15","arabic":"إِنَّهُمۡ يَكِيدُونَ كَيۡدٗا","transliteration":"Innahum yakeedoona kaydan","translation":"","notes":""},{"id":16,"ref":"86:16","arabic":"وَأَكِيدُ كَيۡدٗا","transliteration":"Waakeedu kaydan","translation":"","notes":""},{"id":17,"ref":"86:17","arabic":"فَمَهِّلِ ٱلۡكَٰفِرِينَ أَمۡهِلۡهُمۡ رُوَيۡدَۢا","transliteration":"Famahhili alkafireena amhilhum ruwaydan","translation":"","notes":""}]