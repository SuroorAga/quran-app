[{"id":1,"ref":"87:1","arabic":"سَبِّحِ ٱسۡمَ رَبِّكَ ٱلۡأَعۡلَى","transliteration":"Sabbihi isma rabbika alaAAla","translation":"","notes":""},{"id":2,"ref":"87:2","arabic":"ٱلَّذِي خَلَقَ فَسَوَّىٰ","transliteration":"Allathee khalaqa fasawwa","translation":"","notes":""},{"id":3,"ref":"87:3","arabic":"وَٱلَّذِي قَدَّرَ فَهَدَىٰ","transliteration":"Waallathee qaddara fahada","translation":"","notes":""},{"id":4,"ref":"87:4","arabic":"وَٱلَّذِيٓ أَخۡرَجَ ٱلۡمَرۡعَىٰ","transliteration":"Waallathee akhraja almarAAa","translation":"","notes":""},{"id":5,"ref":"87:5","arabic":"فَجَعَلَهُۥ غُثَآءً أَحۡوَىٰ","transliteration":"FajaAAalahu ghuthaan ahwa","translation":"","notes":""},{"id":6,"ref":"87:6","arabic":"سَنُقۡرِئُكَ فَلَا تَنسَىٰٓ","transliteration":"Sanuqrioka fala tansa","translation":"","notes":""},{"id":7,"ref":"87:7","arabic":"إِلَّا مَا شَآءَ ٱللَّهُۚ إِنَّهُۥ يَعۡلَمُ ٱلۡجَهۡرَ وَمَا يَخۡفَىٰ","transliteration":"Illa ma shaa Allahu innahu yaAAlamu aljahra wama yakhfa","translation":"","notes":""},{"id":8,"ref":"87:8","arabic":"وَنُيَسِّرُكَ لِلۡيُسۡرَىٰ","transliteration":"Wanuyassiruka lilyusra","translation":"","notes":""},{"id":9,"ref":"87:9","arabic":"فَذَكِّرۡ إِن نَّفَعَتِ ٱلذِّكۡرَىٰ","transliteration":"Fathakkir in nafaAAati alththikra","translation":"","notes":""},{"id":10,"ref":"87:10","arabic":"سَيَذَّكَّرُ مَن يَخۡشَىٰ","transliteration":"Sayaththakkaru man yakhsha","translation":"","notes":""},{"id":11,"ref":"87:11","arabic":"وَيَتَجَنَّبُهَا ٱلۡأَشۡقَى","transliteration":"Wayatajannabuha alashqa","translation":"","notes":""},{"id":12,"ref":"87:12","arabic":"ٱلَّذِي يَصۡلَى ٱلنَّارَ ٱلۡكُبۡرَىٰ","transliteration":"Allathee yasla alnnara alkubra","translation":"","notes":""},{"id":13,"ref":"87:13","arabic":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحۡيَىٰ","transliteration":"Thumma la yamootu feeha wala yahya","translation":"","notes":""},{"id":14,"ref":"87:14","arabic":"قَدۡ أَفۡلَحَ مَن تَزَكَّىٰ","transliteration":"Qad aflaha man tazakka","transla