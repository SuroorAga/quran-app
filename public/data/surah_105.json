[{"id":1,"ref":"105:1","arabic":"أَلَمۡ تَرَ كَيۡفَ فَعَلَ رَبُّكَ بِأَصۡحَٰبِ ٱلۡفِيلِ","transliteration":"Alam tara kayfa faAAala rabbuka biashabi alfeeli","translation":"","notes":""},{"id":2,"ref":"105:2","arabic":"أَلَمۡ يَجۡعَلۡ كَيۡدَهُمۡ فِي تَضۡلِيلٖ","transliteration":"Alam yajAAal kaydahum fee tadleelin","translation":"","notes":""},{"id":3,"ref":"105:3","arabic":"وَأَرۡسَلَ عَلَيۡهِمۡ طَيۡرًا أَبَابِيلَ","transliteration":"Waarsala AAalayhim tayran ababeela","translation":"","notes":""},{"id":4,"ref":"105:4","arabic":"تَرۡمِيهِم بِحِجَارَةٖ مِّن سِجِّيلٖ","transliteration":"Tarmeehim bihijaratin min sijjeelin","translation":"","notes":""},{"id":5,"ref":"105:5","arabic":"فَجَعَلَهُمۡ كَعَصۡفٖ مَّأۡكُولِۭ","transliteration":"FajaAAalahum kaAAasfin makoolin","translation":"","notes":""}]