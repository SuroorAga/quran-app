[{"id":1,"ref":"84:1","arabic":"إِذَا ٱلسَّمَآءُ ٱنشَقَّتۡ","transliteration":"Itha alssamao inshaqqat","translation":"","notes":""},{"id":2,"ref":"84:2","arabic":"وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ","transliteration":"Waathinat lirabbiha wahuqqat","translation":"","notes":""},{"id":3,"ref":"84:3","arabic":"وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ","transliteration":"Waitha alardu muddat","translation":"","notes":""},{"id":4,"ref":"84:4","arabic":"وَأَلۡقَتۡ مَا فِيهَا وَتَخَلَّتۡ","transliteration":"Waalqat ma feeha watakhallat","translation":"","notes":""},{"id":5,"ref":"84:5","arabic":"وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ","transliteration":"Waathinat lirabbiha wahuqqat","translation":"","notes":""},{"id":6,"ref":"84:6","arabic":"يَـٰٓأَيُّهَا ٱلۡإِنسَٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدۡحٗا فَمُلَٰقِيهِ","transliteration":"Ya ayyuha alinsanu innaka kadihun ila rabbika kadhan famulaqeehi","translation":"","notes":""},{"id":7,"ref":"84:7","arabic":"فَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ","transliteration":"Faama man ootiya kitabahu biyameenihi","translation":"","notes":""},{"id":8,"ref":"84:8","arabic":"فَسَوۡفَ يُحَاسَبُ حِسَابٗا يَسِيرٗا","transliteration":"Fasawfa yuhasabu hisaban yaseeran","translation":"","notes":""},{"id":9,"ref":"84:9","arabic":"وَيَنقَلِبُ إِلَىٰٓ أَهۡلِهِۦ مَسۡرُورٗا","transliteration":"Wayanqalibu ila ahlihi masrooran","translation":"","notes":""},{"id":10,"ref":"84:10","arabic":"وَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ وَرَآءَ ظَهۡرِهِۦ","transliteration":"Waamma man ootiya kitabahu waraa thahrihi","translation":"","notes":""},{"id":11,"ref":"84:11","arabic":"فَسَوۡفَ يَدۡعُواْ ثُبُورٗا","transliteration":"Fasawfa yadAAoo thubooran","translation":"","notes":""},{"id":12,"ref":"84:12","arabic":"وَيَصۡلَىٰ سَعِيرًا","transliteration":"Wayasla saAAeeran","translation":"","notes":""},{"id":13,"ref":"84:13","arabic":"إِنَّهُۥ كَانَ فِيٓ أَهۡلِهِۦ مَسۡرُورًا","transliteration":"Innahu kana fee ahlihi masrooran","translation":"","notes":""},{"id":14,"ref":"84:14","arabic":"إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ","transliteration":"Innahu thanna an lan yahoora","translation":"","notes":""},{"id":15,"ref":"84:15","arabic":"بَلَىٰٓۚ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرٗا","transliteration":"Bala inna rabbahu kana bihi baseeran","translation":"","notes":""},{"id":16,"ref":"84:16","arabic":"فَلَآ أُقۡسِمُ بِٱلشَّفَقِ","transliteration":"Fala oqsimu bialshshafaqi","translation":"","notes":""},{"id":17,"ref":"84:17","arabic":"وَٱلَّيۡلِ وَمَا وَسَقَ","transliteration":"Waallayli wama wasaqa","translation":"","notes":""},{"id":18,"ref":"84:18","arabic":"وَٱلۡقَمَرِ إِذَا ٱتَّسَقَ","transliteration":"Waalqamari itha ittasaqa","translation":"","notes":""},{"id":19,"ref":"84:19","arabic":"لَتَرۡكَبُنَّ طَبَقًا عَن طَبَقٖ","transliteration":"Latarkabunna tabaqan AAan tabaqin","translation":"","notes":""},{"id":20,"ref":"84:20","arabic":"فَمَا لَهُمۡ لَا يُؤۡمِنُونَ","transliteration":"Fama lahum la yuminoona","translation":"","notes":""},{"id":21,"ref":"84:21","arabic":"وَإِذَا قُرِئَ عَلَيۡهِمُ ٱلۡقُرۡءَانُ لَا يَسۡجُدُونَۤ۩","transliteration":"Waitha quria AAalayhimu alquranu la yasjudoona","translation":"","notes":""},{"id":22,"ref":"84:22","arabic":"بَلِ ٱلَّذِينَ كَفَرُواْ يُكَذِّبُونَ","transliteration":"Bali allatheena kafaroo yukaththiboona","translation":"","notes":""},{"id":23,"ref":"84:23","arabic":"وَٱللَّهُ أَعۡلَمُ بِمَا يُوعُونَ","transliteration":"WaAllahu aAAlamu bima yooAAoona","translation":"","notes":""},{"id":24,"ref":"84:24","arabic":"فَبَشِّرۡهُم بِعَذَابٍ أَلِيمٍ","transliteration":"Fabashshirhum biAAathabin aleemin","translation":"","notes":""},{"id":25,"ref":"84:25","arabic":"إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّـٰلِحَٰتِ لَهُمۡ أَجۡرٌ غَيۡرُ مَمۡنُونِۭ","transliteration":"Illa allatheena amanoo waAAamiloo alssalihati lahum ajrun ghayru mamnoonin","translation":"","notes":""}]