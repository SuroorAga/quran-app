[{"id":1,"ref":"37:1","arabic":"وَٱلصَّـٰٓفَّـٰتِ صَفّٗا","transliteration":"Waalssaffati saffan","translation":"","notes":""},{"id":2,"ref":"37:2","arabic":"فَٱلزَّـٰجِرَٰتِ زَجۡرٗا","transliteration":"Faalzzajirati zajran","translation":"","notes":""},{"id":3,"ref":"37:3","arabic":"فَٱلتَّـٰلِيَٰتِ ذِكۡرًا","transliteration":"Faalttaliyati thikran","translation":"","notes":""},{"id":4,"ref":"37:4","arabic":"إِنَّ إِلَٰهَكُمۡ لَوَٰحِدٞ","transliteration":"Inna ilahakum lawahidun","translation":"","notes":""},{"id":5,"ref":"37:5","arabic":"رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ وَمَا بَيۡنَهُمَا وَرَبُّ ٱلۡمَشَٰرِقِ","transliteration":"Rabbu alssamawati waalardi wama baynahuma warabbu almashariqi","translation":"","notes":""},{"id":6,"ref":"37:6","arabic":"إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنۡيَا بِزِينَةٍ ٱلۡكَوَاكِبِ","transliteration":"Inna zayyanna alssamaa alddunya bizeenatin alkawakibi","translation":"","notes":""},{"id":7,"ref":"37:7","arabic":"وَحِفۡظٗا مِّن كُلِّ شَيۡطَٰنٖ مَّارِدٖ","transliteration":"Wahifthan min kulli shaytanin maridin","translation":"","notes":""},{"id":8,"ref":"37:8","arabic":"لَّا يَسَّمَّعُونَ إِلَى ٱلۡمَلَإِ ٱلۡأَعۡلَىٰ وَيُقۡذَفُونَ مِن كُلِّ جَانِبٖ","transliteration":"La yassammaAAoona ila almalai alaAAla wayuqthafoona min kulli janibin","translation":"","notes":""},{"id":9,"ref":"37:9","arabic":"دُحُورٗاۖ وَلَهُمۡ عَذَابٞ وَاصِبٌ","transliteration":"Duhooran walahum AAathabun wasibun","translation":"","notes":""},{"id":10,"ref":"37:10","arabic":"إِلَّا مَنۡ خَطِفَ ٱلۡخَطۡفَةَ فَأَتۡبَعَهُۥ شِهَابٞ ثَاقِبٞ","transliteration":"Illa man khatifa alkhatfata faatbaAAahu shihabun thaqibun","translation":"","notes":""},{"id":11,"ref":"37:11","arabic":"فَٱسۡتَفۡتِهِمۡ أَهُمۡ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَآۚ إِنَّا خَلَقۡنَٰهُم مِّن طِينٖ لَّازِبِۭ","transliteration":"Faistaftihim ahum ashaddu khalqan am man khalaqna inna khalaqnahum min teenin lazibin","translation":"","notes":""},{"id":12,"ref":"37:12","arabic":"بَلۡ عَجِبۡتَ وَيَسۡخَرُونَ","transliteration":"Bal AAajibta wayaskharoona","translation":"","notes":""},{"id":13,"ref":"37:13","arabic":"وَإِذَا ذُكِّرُواْ لَا يَذۡكُرُونَ","transliteration":"Waitha thukkiroo la yathkuroona","translation":"","notes":""},{"id":14,"ref":"37:14","arabic":"وَإِذَا رَأَوۡاْ ءَايَةٗ يَسۡتَسۡخِرُونَ","transliteration":"Waitha raaw ayatan yastaskhiroona","translation":"","notes":""},{"id":15,"ref":"37:15","arabic":"وَقَالُوٓاْ إِنۡ هَٰذَآ إِلَّا سِحۡرٞ مُّبِينٌ","transliteration":"Waqaloo in hatha illa sihrun mubeenun","translation":"","notes":""},{"id":16,"ref":"37:16","arabic":"أَءِذَا مِتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَءِنَّا لَمَبۡعُوثُونَ","transliteration":"Aitha mitna wakunna turaban waAAithaman ainna lamabAAoothoona","translation":"","notes":""},{"id":17,"ref":"37:17","arabic":"أَوَءَابَآؤُنَا ٱلۡأَوَّلُونَ","transliteration":"Awaabaona alawwaloona","translation":"","notes":""},{"id":18,"ref":"37:18","arabic":"قُلۡ نَعَمۡ وَأَنتُمۡ دَٰخِرُونَ","transliteration":"Qul naAAam waantum dakhiroona","translation":"","notes":""},{"id":19,"ref":"37:19","arabic":"فَإِنَّمَا هِيَ زَجۡرَةٞ وَٰحِدَةٞ فَإِذَا هُمۡ يَنظُرُونَ","transliteration":"Fainnama hiya zajratun wahidatun faitha hum yanthuroona","translation":"","notes":""},{"id":20,"ref":"37:20","arabic":"وَقَالُواْ يَٰوَيۡلَنَا هَٰذَا يَوۡمُ ٱلدِّينِ","transliteration":"Waqaloo ya waylana hatha yawmu alddeeni","translation":"","notes":""},{"id":21,"ref":"37:21","arabic":"هَٰذَا يَوۡمُ ٱلۡفَصۡلِ ٱلَّذِي كُنتُم بِهِۦ تُكَذِّبُونَ","transliteration":"Hatha yawmu alfasli allathee kuntum bihi tukaththiboona","translation":"","notes":""},{"id":22,"ref":"37:22","arabic":"۞ٱحۡشُرُواْ ٱلَّذِينَ ظَلَمُواْ وَأَزۡوَٰجَهُمۡ وَمَا كَانُواْ يَعۡبُدُونَ","transliteration":"Ohshuroo allatheena thalamoo waazwajahum wama kanoo yaAAbudoona","translation":"","notes":""},{"id":23,"ref":"37:23","arabic":"مِن دُونِ ٱللَّهِ فَٱهۡدُوهُمۡ إِلَىٰ صِرَٰطِ ٱلۡجَحِيمِ","transliteration":"Min dooni Allahi faihdoohum ila sirati aljaheemi","translation":"","notes":""},{"id":24,"ref":"37:24","arabic":"وَقِفُوهُمۡۖ إِنَّهُم مَّسۡـُٔولُونَ","transliteration":"Waqifoohum innahum masooloona","translation":"","notes":""},{"id":25,"ref":"37:25","arabic":"مَا لَكُمۡ لَا تَنَاصَرُونَ","transliteration":"Ma lakum la tanasaroona","translation":"","notes":""},{"id":26,"ref":"37:26","arabic":"بَلۡ هُمُ ٱلۡيَوۡمَ مُسۡتَسۡلِمُونَ","transliteration":"Bal humu alyawma mustaslimoona","translation":"","notes":""},{"id":27,"ref":"37:27","arabic":"وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ","transliteration":"Waaqbala baAAduhum AAala baAAdin yatasaaloona","translation":"","notes":""},{"id":28,"ref":"37:28","arabic":"قَالُوٓاْ إِنَّكُمۡ كُنتُمۡ تَأۡتُونَنَا عَنِ ٱلۡيَمِينِ","transliteration":"Qaloo innakum kuntum tatoonana AAani alyameeni","translation":"","notes":""},{"id":29,"ref":"37:29","arabic":"قَالُواْ بَل لَّمۡ تَكُونُواْ مُؤۡمِنِينَ","transliteration":"Qaloo bal lam takoonoo mumineena","translation":"","notes":""},{"id":30,"ref":"37:30","arabic":"وَمَا كَانَ لَنَا عَلَيۡكُم مِّن سُلۡطَٰنِۭۖ بَلۡ كُنتُمۡ قَوۡمٗا طَٰغِينَ","transliteration":"Wama kana lana AAalaykum min sultanin bal kuntum qawman tagheena","translation":"","notes":""},{"id":31,"ref":"37:31","arabic":"فَحَقَّ عَلَيۡنَا قَوۡلُ رَبِّنَآۖ إِنَّا لَذَآئِقُونَ","transliteration":"Fahaqqa AAalayna qawlu rabbina inna lathaiqoona","translation":"","notes":""},{"id":32,"ref":"37:32","arabic":"فَأَغۡوَيۡنَٰكُمۡ إِنَّا كُنَّا غَٰوِينَ","transliteration":"Faaghwaynakum inna kunna ghaweena","translation":"","notes":""},{"id":33,"ref":"37:33","arabic":"فَإِنَّهُمۡ يَوۡمَئِذٖ فِي ٱلۡعَذَابِ مُشۡتَرِكُونَ","transliteration":"Fainnahum yawmaithin fee alAAathabi mushtarikoona","translation":"","notes":""},{"id":34,"ref":"37:34","arabic":"إِنَّا كَذَٰلِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِينَ","transliteration":"Inna kathalika nafAAalu bialmujrimeena","translation":"","notes":""},{"id":35,"ref":"37:35","arabic":"إِنَّهُمۡ كَانُوٓاْ إِذَا قِيلَ لَهُمۡ لَآ إِلَٰهَ إِلَّا ٱللَّهُ يَسۡتَكۡبِرُونَ","transliteration":"Innahum kanoo itha qeela lahum la ilaha illa Allahu yastakbiroona","translation":"","notes":""},{"id":36,"ref":"37:36","arabic":"وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓاْ ءَالِهَتِنَا لِشَاعِرٖ مَّجۡنُونِۭ","transliteration":"Wayaqooloona ainna latarikoo alihatina lishaAAirin majnoonin","translation":"","notes":""},{"id":37,"ref":"37:37","arabic":"بَلۡ جَآءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِينَ","transliteration":"Bal jaa bialhaqqi wasaddaqa almursaleena","translation":"","notes":""},{"id":38,"ref":"37:38","arabic":"إِنَّكُمۡ لَذَآئِقُواْ ٱلۡعَذَابِ ٱلۡأَلِيمِ","transliteration":"Innakum lathaiqoo alAAathabi alaleemi","translation":"","notes":""},{"id":39,"ref":"37:39","arabic":"وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ","transliteration":"Wama tujzawna illa ma kuntum taAAmaloona","translation":"","notes":""},{"id":40,"ref":"37:40","arabic":"إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ","transliteration":"Illa AAibada Allahi almukhlaseena","translation":"","notes":""},{"id":41,"ref":"37:41","arabic":"أُوْلَـٰٓئِكَ لَهُمۡ رِزۡقٞ مَّعۡلُومٞ","transliteration":"Olaika lahum rizqun maAAloomun","translation":"","notes":""},{"id":42,"ref":"37:42","arabic":"فَوَٰكِهُ وَهُم مُّكۡرَمُونَ","transliteration":"Fawakihu wahum mukramoona","translation":"","notes":""},{"id":43,"ref":"37:43","arabic":"فِي جَنَّـٰتِ ٱلنَّعِيمِ","transliteration":"Fee jannati alnnaAAeemi","translation":"","notes":""},{"id":44,"ref":"37:44","arabic":"عَلَىٰ سُرُرٖ مُّتَقَٰبِلِينَ","transliteration":"AAala sururin mutaqabileena","translation":"","notes":""},{"id":45,"ref":"37:45","arabic":"يُطَافُ عَلَيۡهِم بِكَأۡسٖ مِّن مَّعِينِۭ","transliteration":"Yutafu AAalayhim bikasin min maAAeenin","translation":"","notes":""},{"id":46,"ref":"37:46","arabic":"بَيۡضَآءَ لَذَّةٖ لِّلشَّـٰرِبِينَ","transliteration":"Baydaa laththatin lilshsharibeena","translation":"","notes":""},{"id":47,"ref":"37:47","arabic":"لَا فِيهَا غَوۡلٞ وَلَا هُمۡ عَنۡهَا يُنزَفُونَ","transliteration":"La feeha ghawlun wala hum AAanha yunzafoona","translation":"","notes":""},{"id":48,"ref":"37:48","arabic":"وَعِندَهُمۡ قَٰصِرَٰتُ ٱلطَّرۡفِ عِينٞ","transliteration":"WaAAindahum qasiratu alttarfi AAeenun","translation":"","notes":""},{"id":49,"ref":"37:49","arabic":"كَأَنَّهُنَّ بَيۡضٞ مَّكۡنُونٞ","transliteration":"Kaannahunna baydun maknoonun","translation":"","notes":""},{"id":50,"ref":"37:50","arabic":"فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ","transliteration":"Faaqbala baAAduhum AAala baAAdin yatasaaloona","translation":"","notes":""},{"id":51,"ref":"37:51","arabic":"قَالَ قَآئِلٞ مِّنۡهُمۡ إِنِّي كَانَ لِي قَرِينٞ","transliteration":"Qala qailun minhum innee kana lee qareenun","translation":"","notes":""},{"id":52,"ref":"37:52","arabic":"يَقُولُ أَءِنَّكَ لَمِنَ ٱلۡمُصَدِّقِينَ","transliteration":"Yaqoolu ainnaka lamina almusaddiqeena","translation":"","notes":""},{"id":53,"ref":"37:53","arabic":"أَءِذَا مِتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَءِنَّا لَمَدِينُونَ","transliteration":"Aitha mitna wakunna turaban waAAithaman ainna lamadeenoona","translation":"","notes":""},{"id":54,"ref":"37:54","arabic":"قَالَ هَلۡ أَنتُم مُّطَّلِعُونَ","transliteration":"Qala hal antum muttaliAAoona","translation":"","notes":""},{"id":55,"ref":"37:55","arabic":"فَٱطَّلَعَ فَرَءَاهُ فِي سَوَآءِ ٱلۡجَحِيمِ","transliteration":"FaittalaAAa faraahu fee sawai aljaheemi","translation":"","notes":""},{"id":56,"ref":"37:56","arabic":"قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرۡدِينِ","transliteration":"Qala taAllahi in kidta laturdeeni","translation":"","notes":""},{"id":57,"ref":"37:57","arabic":"وَلَوۡلَا نِعۡمَةُ رَبِّي لَكُنتُ مِنَ ٱلۡمُحۡضَرِينَ","transliteration":"Walawla niAAmatu rabbee lakuntu mina almuhdareena","translation":"","notes":""},{"id":58,"ref":"37:58","arabic":"أَفَمَا نَحۡنُ بِمَيِّتِينَ","transliteration":"Afama nahnu bimayyiteena","translation":"","notes":""},{"id":59,"ref":"37:59","arabic":"إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِينَ","transliteration":"Illa mawtatana aloola wama nahnu bimuAAaththabeena","translation":"","notes":""},{"id":60,"ref":"37:60","arabic":"إِنَّ هَٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِيمُ","transliteration":"Inna hatha lahuwa alfawzu alAAatheemu","translation":"","notes":""},{"id":61,"ref":"37:61","arabic":"لِمِثۡلِ هَٰذَا فَلۡيَعۡمَلِ ٱلۡعَٰمِلُونَ","transliteration":"Limithli hatha falyaAAmali alAAamiloona","translation":"","notes":""},{"id":62,"ref":"37:62","arabic":"أَذَٰلِكَ خَيۡرٞ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ","transliteration":"Athalika khayrun nuzulan am shajaratu alzzaqqoomi","translation":"","notes":""},{"id":63,"ref":"37:63","arabic":"إِنَّا جَعَلۡنَٰهَا فِتۡنَةٗ لِّلظَّـٰلِمِينَ","transliteration":"Inna jaAAalnaha fitnatan lilththalimeena","translation":"","notes":""},{"id":64,"ref":"37:64","arabic":"إِنَّهَا شَجَرَةٞ تَخۡرُجُ فِيٓ أَصۡلِ ٱلۡجَحِيمِ","transliteration":"Innaha shajaratun takhruju fee asli aljaheemi","translation":"","notes":""},{"id":65,"ref":"37:65","arabic":"طَلۡعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَٰطِينِ","transliteration":"TalAAuha kaannahu ruoosu alshshayateeni","translation":"","notes":""},{"id":66,"ref":"37:66","arabic":"فَإِنَّهُمۡ لَأٓكِلُونَ مِنۡهَا فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ","transliteration":"Fainnahum laakiloona minha famalioona minha albutoona","translation":"","notes":""},{"id":67,"ref":"37:67","arabic":"ثُمَّ إِنَّ لَهُمۡ عَلَيۡهَا لَشَوۡبٗا مِّنۡ حَمِيمٖ","transliteration":"Thumma inna lahum AAalayha lashawban min hameemin","translation":"","notes":""},{"id":68,"ref":"37:68","arabic":"ثُمَّ إِنَّ مَرۡجِعَهُمۡ لَإِلَى ٱلۡجَحِيمِ","transliteration":"Thumma inna marjiAAahum laila aljaheemi","translation":"","notes":""},{"id":69,"ref":"37:69","arabic":"إِنَّهُمۡ أَلۡفَوۡاْ ءَابَآءَهُمۡ ضَآلِّينَ","transliteration":"Innahum alfaw abaahum dalleena","translation":"","notes":""},{"id":70,"ref":"37:70","arabic":"فَهُمۡ عَلَىٰٓ ءَاثَٰرِهِمۡ يُهۡرَعُونَ","transliteration":"Fahum AAala atharihim yuhraAAoona","translation":"","notes":""},{"id":71,"ref":"37:71","arabic":"وَلَقَدۡ ضَلَّ قَبۡلَهُمۡ أَكۡثَرُ ٱلۡأَوَّلِينَ","transliteration":"Walaqad dalla qablahum aktharu alawwaleena","translation":"","notes":""},{"id":72,"ref":"37:72","arabic":"وَلَقَدۡ أَرۡسَلۡنَا فِيهِم مُّنذِرِينَ","transliteration":"Walaqad arsalna feehim munthireena","translation":"","notes":""},{"id":73,"ref":"37:73","arabic":"فَٱنظُرۡ كَيۡفَ كَانَ عَٰقِبَةُ ٱلۡمُنذَرِينَ","transliteration":"Faonthur kayfa kana AAaqibatu almunthareena","translation":"","notes":""},{"id":74,"ref":"37:74","arabic":"إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ","transliteration":"Illa AAibada Allahi almukhlaseena","translation":"","notes":""},{"id":75,"ref":"37:75","arabic":"وَلَقَدۡ نَادَىٰنَا نُوحٞ فَلَنِعۡمَ ٱلۡمُجِيبُونَ","transliteration":"Walaqad nadana noohun falaniAAma almujeeboona","translation":"","notes":""},{"id":76,"ref":"37:76","arabic":"وَنَجَّيۡنَٰهُ وَأَهۡلَهُۥ مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ","transliteration":"Wanajjaynahu waahlahu mina alkarbi alAAatheemi","translation":"","notes":""},{"id":77,"ref":"37:77","arabic":"وَجَعَلۡنَا ذُرِّيَّتَهُۥ هُمُ ٱلۡبَاقِينَ","transliteration":"WajaAAalna thurriyyatahu humu albaqeena","translation":"","notes":""},{"id":78,"ref":"37:78","arabic":"وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ","transliteration":"Watarakna AAalayhi fee alakhireena","translation":"","notes":""},{"id":79,"ref":"37:79","arabic":"سَلَٰمٌ عَلَىٰ نُوحٖ فِي ٱلۡعَٰلَمِينَ","transliteration":"Salamun AAala noohin fee alAAalameena","translation":"","notes":""},{"id":80,"ref":"37:80","arabic":"إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ","transliteration":"Inna kathalika najzee almuhsineena","translation":"","notes":""},{"id":81,"ref":"37:81","arabic":"إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ","transliteration":"Innahu min AAibadina almumineena","translation":"","notes":""},{"id":82,"ref":"37:82","arabic":"ثُمَّ أَغۡرَقۡنَا ٱلۡأٓخَرِينَ","transliteration":"Thumma aghraqna alakhareena","translation":"","notes":""},{"id":83,"ref":"37:83","arabic":"۞وَإِنَّ مِن ش