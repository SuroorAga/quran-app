":"","notes":""},{"id":179,"ref":"37:179","arabic":"وَأَبۡصِرۡ فَسَوۡفَ يُبۡصِرُونَ","transliteration":"Waabsir fasawfa yubsiroona","translation":"","notes":""},{"id":180,"ref":"37:180","arabic":"سُبۡحَٰنَ رَبِّكَ رَبِّ ٱلۡعِزَّةِ عَمَّا يَصِفُونَ","transliteration":"Subhana rabbika rabbi alAAizzati AAamma yasifoona","translation":"","notes":""},{"id":181,"ref":"37:181","arabic":"وَسَلَٰمٌ عَلَى ٱلۡمُرۡسَلِينَ","transliteration":"Wasalamun AAala almursaleena","translation":"","notes":""},{"id":182,"ref":"37:182","arabic":"وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَٰلَمِينَ","transliteration":"Waalhamdu lillahi rabbi alAAalameena","translation":"","notes":""}]