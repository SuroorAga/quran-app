[{"id":1,"ref":"90:1","arabic":"لَآ أُقۡسِمُ بِهَٰذَا ٱلۡبَلَدِ","transliteration":"La oqsimu bihatha albaladi","translation":"","notes":""},{"id":2,"ref":"90:2","arabic":"وَأَنتَ حِلُّۢ بِهَٰذَا ٱلۡبَلَدِ","transliteration":"Waanta hillun bihatha albaladi","translation":"","notes":""},{"id":3,"ref":"90:3","arabic":"وَوَالِدٖ وَمَا وَلَدَ","transliteration":"Wawalidin wama walada","translation":"","notes":""},{"id":4,"ref":"90:4","arabic":"لَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ فِي كَبَدٍ","transliteration":"Laqad khalaqna alinsana fee kabadin","translation":"","notes":""},{"id":5,"ref":"90:5","arabic":"أَيَحۡسَبُ أَن لَّن يَقۡدِرَ عَلَيۡهِ أَحَدٞ","transliteration":"Ayahsabu an lan yaqdira AAalayhi ahadun","translation":"","notes":""},{"id":6,"ref":"90:6","arabic":"يَقُولُ أَهۡلَكۡتُ مَالٗا لُّبَدًا","transliteration":"Yaqoolu ahlaktu malan lubadan","translation":"","notes":""},{"id":7,"ref":"90:7","arabic":"أَيَحۡسَبُ أَن لَّمۡ يَرَهُۥٓ أَحَدٌ","transliteration":"Ayahsabu an lam yarahu ahadun","translation":"","notes":""},{"id":8,"ref":"90:8","arabic":"أَلَمۡ نَجۡعَل لَّهُۥ عَيۡنَيۡنِ","transliteration":"Alam najAAal lahu AAaynayni","translation":"","notes":""},{"id":9,"ref":"90:9","arabic":"وَلِسَانٗا وَشَفَتَيۡنِ","transliteration":"Walisanan washafatayni","translation":"","notes":""},{"id":10,"ref":"90:10","arabic":"وَهَدَيۡنَٰهُ ٱلنَّجۡدَيۡنِ","transliteration":"Wahadaynahu alnnajdayni","translation":"","notes":""},{"id":11,"ref":"90:11","arabic":"فَلَا ٱقۡتَحَمَ ٱلۡعَقَبَةَ","transliteration":"Fala iqtahama alAAaqabata","translation":"","notes":""},{"id":12,"ref":"90:12","arabic":"وَمَآ أَدۡرَىٰكَ مَا ٱلۡعَقَبَةُ","transliteration":"Wama adraka ma alAAaqabatu","translation":"","notes":""},{"id":13,"ref":"90:13","arabic":"فَكُّ رَقَبَةٍ","transliteration":"Fakku raqabatin","translation":"","notes":""},{"id":14,"ref":"90:14","arabic":"أَوۡ إِطۡعَٰمٞ فِي يَوۡمٖ ذِي مَسۡغَبَةٖ","transliteration":"Aw itAAamun fee yawmin thee masghabatin","translation":"","notes":""},{"id":15,"ref":"90:15","arabic":"يَتِيمٗا ذَا مَقۡرَبَةٍ","transliteration":"Yateeman tha maqrabatin","translation":"","notes":""},{"id":16,"ref":"90:16","arabic":"أَوۡ مِسۡكِينٗا ذَا مَتۡرَبَةٖ","transliteration":"Aw miskeenan tha matrabatin","translation":"","notes":""},{"id":17,"ref":"90:17","arabic":"ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُواْ وَتَوَاصَوۡاْ بِٱلصَّبۡرِ وَتَوَاصَوۡاْ بِٱلۡمَرۡحَمَةِ","transliteration":"Thumma kana mina allatheena amanoo watawasaw bialssabri watawasaw bialmarhamati","translation":"","notes":""},{"id":18,"ref":"90:18","arabic":"أُوْلَـٰٓئِكَ أَصۡحَٰبُ ٱلۡمَيۡمَنَةِ","transliteration":"Olaika ashabu almaymanati","translation":"","notes":""},{"id":19,"ref":"90:19","arabic":"وَٱلَّذِينَ كَفَرُواْ بِـَٔايَٰتِنَا هُمۡ أَصۡحَٰبُ ٱلۡمَشۡـَٔمَةِ","transliteration":"Waallatheena kafaroo biayatina hum ashabu almashamati","translation":"","notes":""},{"id":20,"ref":"90:20","arabic":"عَلَيۡهِمۡ نَارٞ مُّؤۡصَدَةُۢ","transliteration":"AAalayhim narun musadatun","translation":"","notes":""}]