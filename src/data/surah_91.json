[{"id":1,"ref":"91:1","arabic":"وَٱلشَّمۡسِ وَضُحَىٰهَا","transliteration":"Waalshshamsi waduhaha","translation":"","notes":""},{"id":2,"ref":"91:2","arabic":"وَٱلۡقَمَرِ إِذَا تَلَىٰهَا","transliteration":"Waalqamari itha talaha","translation":"","notes":""},{"id":3,"ref":"91:3","arabic":"وَٱلنَّهَارِ إِذَا جَلَّىٰهَا","transliteration":"Waalnnahari itha jallaha","translation":"","notes":""},{"id":4,"ref":"91:4","arabic":"وَٱلَّيۡلِ إِذَا يَغۡشَىٰهَا","transliteration":"Waallayli itha yaghshaha","translation":"","notes":""},{"id":5,"ref":"91:5","arabic":"وَٱلسَّمَآءِ وَمَا بَنَىٰهَا","transliteration":"Waalssamai wama banaha","translation":"","notes":""},{"id":6,"ref":"91:6","arabic":"وَٱلۡأَرۡضِ وَمَا طَحَىٰهَا","transliteration":"Waalardi wama tahaha","translation":"","notes":""},{"id":7,"ref":"91:7","arabic":"وَنَفۡسٖ وَمَا سَوَّىٰهَا","transliteration":"Wanafsin wama sawwaha","translation":"","notes":""},{"id":8,"ref":"91:8","arabic":"فَأَلۡهَمَهَا فُجُورَهَا وَتَقۡوَىٰهَا","transliteration":"Faalhamaha fujooraha wataqwaha","translation":"","notes":""},{"id":9,"ref":"91:9","arabic":"قَدۡ أَفۡلَحَ مَن زَكَّىٰهَا","transliteration":"Qad aflaha man zakkaha","translation":"","notes":""},{"id":10,"ref":"91:10","arabic":"وَقَدۡ خَابَ مَن دَسَّىٰهَا","transliteration":"Waqad khaba man dassaha","translation":"","notes":""},{"id":11,"ref":"91:11","arabic":"كَذَّبَتۡ ثَمُودُ بِطَغۡوَىٰهَآ","transliteration":"Kaththabat thamoodu bitaghwaha","translation":"","notes":""},{"id":12,"ref":"91:12","arabic":"إِذِ ٱنۢبَعَثَ أَشۡقَىٰهَا","transliteration":"Ithi inbaAAatha ashqaha","translation":"","notes":""},{"id":13,"ref":"91:13","arabic":"فَقَالَ لَهُمۡ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقۡيَٰهَا","transliteration":"Faqala lahum rasoolu Allahi naqata Allahi wasuqyaha","translation":"","notes":""},{"id":14,"ref":"91:14","arabic":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمۡدَمَ عَلَيۡهِمۡ رَبُّهُم بِذَنۢبِهِمۡ فَسَوَّىٰهَا","transliteration":"Fakaththaboohu faAAaqarooha fadamdama AAalayh