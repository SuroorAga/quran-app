9","arabic":"ٱنطَلِقُوٓاْ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ","transliteration":"Intaliqoo ila ma kuntum bihi tukaththiboona","translation":"","notes":""},{"id":30,"ref":"77:30","arabic":"ٱنطَلِقُوٓاْ إِلَىٰ ظِلّٖ ذِي ثَلَٰثِ شُعَبٖ","transliteration":"Intaliqoo ila thillin thee thalathi shuAAabin","translation":"","notes":""},{"id":31,"ref":"77:31","arabic":"لَّا ظَلِيلٖ وَلَا يُغۡنِي مِنَ ٱللَّهَبِ","transliteration":"La thaleelin wala yughnee mina allahabi","translation":"","notes":""},{"id":32,"ref":"77:32","arabic":"إِنَّهَا تَرۡمِي بِشَرَرٖ كَٱلۡقَصۡرِ","transliteration":"Innaha tarmee bishararin kaalqasri","translation":"","notes":""},{"id":33,"ref":"77:33","arabic":"كَأَنَّهُۥ جِمَٰلَتٞ صُفۡرٞ","transliteration":"Kaannahu jimalatun sufrun","translation":"","notes":""},{"id":34,"ref":"77:34","arabic":"وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ","transliteration":"Waylun yawmaithin lilmukaththibeena","translation":"","notes":""},{"id":35,"ref":"77:35","arabic":"هَٰذَا يَوۡمُ لَا يَنطِقُونَ","transliteration":"Hatha yawmu la yantiqoona","translation":"","notes":""},{"id":36,"ref":"77:36","arabic":"وَلَا يُؤۡذَنُ لَهُمۡ فَيَعۡتَذِرُونَ","transliteration":"Wala yuthanu lahum fayaAAtathiroona","translation":"","notes":""},{"id":37,"ref":"77:37","arabic":"وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ","transliteration":"Waylun yawmaithin lilmukaththibeena","translation":"","notes":""},{"id":38,"ref":"77:38","arabic":"هَٰذَا يَوۡمُ ٱلۡفَصۡلِۖ جَمَعۡنَٰكُمۡ وَٱلۡأَوَّلِينَ","transliteration":"Hatha yawmu alfasli jamaAAnakum waalawwaleena","translation":"","notes":""},{"id":39,"ref":"77:39","arabic":"فَإِن كَانَ لَكُمۡ كَيۡدٞ فَكِيدُونِ","transliteration":"Fain kana lakum kaydun fakeedooni","translation":"","notes":""},{"id":40,"ref":"77:40","arabic":"وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ","transliteration":"Waylun yawmaithin lilmukaththibeena","translation":"","notes":""},{"id":41,"ref":"77:41","arabic":"إِنَّ ٱلۡمُتَّقِينَ فِي ظِلَٰلٖ وَعُيُونٖ","transliteration":"Inna almuttaqeena 