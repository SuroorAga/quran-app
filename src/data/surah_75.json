[{"id":1,"ref":"75:1","arabic":"لَآ أُقۡسِمُ بِيَوۡمِ ٱلۡقِيَٰمَةِ","transliteration":"La oqsimu biyawmi alqiyamati","translation":"","notes":""},{"id":2,"ref":"75:2","arabic":"وَلَآ أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ","transliteration":"Wala oqsimu bialnnafsi allawwamati","translation":"","notes":""},{"id":3,"ref":"75:3","arabic":"أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ","transliteration":"Ayahsabu alinsanu allan najmaAAa AAithamahu","translation":"","notes":""},{"id":4,"ref":"75:4","arabic":"بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّيَ بَنَانَهُۥ","transliteration":"Bala qadireena AAala an nusawwiya bananahu","translation":"","notes":""},{"id":5,"ref":"75:5","arabic":"بَلۡ يُرِيدُ ٱلۡإِنسَٰنُ لِيَفۡجُرَ أَمَامَهُۥ","transliteration":"Bal yureedu alinsanu liyafjura amamahu","translation":"","notes":""},{"id":6,"ref":"75:6","arabic":"يَسۡـَٔلُ أَيَّانَ يَوۡمُ ٱلۡقِيَٰمَةِ","transliteration":"Yasalu ayyana yawmu alqiyamati","translation":"","notes":""},{"id":7,"ref":"75:7","arabic":"فَإِذَا بَرِقَ ٱلۡبَصَرُ","transliteration":"Faitha bariqa albasaru","translation":"","notes":""},{"id":8,"ref":"75:8","arabic":"وَخَسَفَ ٱلۡقَمَرُ","transliteration":"Wakhasafa alqamaru","translation":"","notes":""},{"id":9,"ref":"75:9","arabic":"وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ","transliteration":"WajumiAAa alshshamsu waalqamaru","translation":"","notes":""},{"id":10,"ref":"75:10","arabic":"يَقُولُ ٱلۡإِنسَٰنُ يَوۡمَئِذٍ أَيۡنَ ٱلۡمَفَرُّ","transliteration":"Yaqoolu alinsanu yawmaithin ayna almafarru","translation":"","notes":""},{"id":11,"ref":"75:11","arabic":"كَلَّا لَا وَزَرَ","transliteration":"Kalla la wazara","translation":"","notes":""},{"id":12,"ref":"75:12","arabic":"إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمُسۡتَقَرُّ","transliteration":"Ila rabbika yawmaithin almustaqarru","translation":"","notes":""},{"id":13,"ref":"75:13","arabic":"يُنَبَّؤُاْ ٱلۡإِنسَٰنُ يَوۡمَئِذِۭ بِمَا قَدَّمَ وَأَخَّرَ","transliteration":"Yunabbao alinsanu yawmaithin bima qaddama waakhkhara","translation":"","notes":""},{"id":14,"ref":"75:14","arabic":"بَلِ ٱلۡإِنسَٰنُ عَلَىٰ نَفۡسِهِۦ بَصِيرَةٞ","transliteration":"Bali alinsanu AAala nafsihi baseeratun","translation":"","notes":""},{"id":15,"ref":"75:15","arabic":"وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ","transliteration":"Walaw alqa maAAatheerahu","translation":"","notes":""},{"id":16,"ref":"75:16","arabic":"لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦٓ","transliteration":"La tuharrik bihi lisanaka litaAAjala bihi","translation":"","notes":""},{"id":17,"ref":"75:17","arabic":"إِنَّ عَلَيۡنَا جَمۡعَهُۥ وَقُرۡءَانَهُۥ","transliteration":"Inna AAalayna jamAAahu waquranahu","translation":"","notes":""},{"id":18,"ref":"75:18","arabic":"فَإِذَا قَرَأۡنَٰهُ فَٱتَّبِعۡ قُرۡءَانَهُۥ","transliteration":"Faitha qaranahu faittabiAA quranahu","translation":"","notes":""},{"id":19,"ref":"75:19","arabic":"ثُمَّ إِنَّ عَلَيۡنَا بَيَانَهُۥ","transliteration":"Thumma inna AAalayna bayanahu","translation":"","notes":""},{"id":20,"ref":"75:20","arabic":"كَلَّا بَلۡ تُحِبُّونَ ٱلۡعَاجِلَةَ","transliteration":"Kalla bal tuhibboona alAAajilata","translation":"","notes":""},{"id":21,"ref":"75:21","arabic":"وَتَذَرُونَ ٱلۡأٓخِرَةَ","transliteration":"Watatharoona alakhirata","translation":"","notes":""},{"id":22,"ref":"75:22","arabic":"وُجُوهٞ يَوۡمَئِذٖ نَّاضِرَةٌ","transliteration":"Wujoohun yawmaithin nadiratun","translation":"","notes":""},{"id":23,"ref":"75:23","arabic":"إِلَىٰ رَبِّهَا نَاظِرَةٞ","transliteration":"Ila rabbiha nathiratun","translation":"","notes":""},{"id":24,"ref":"75:24","arabic":"وَوُجُوهٞ يَوۡمَئِذِۭ بَاسِرَةٞ","transliteration":"Wawujoohun yawmaithin basiratun","translation":"","notes":""},{"id":25,"ref":"75:25","arabic":"تَظُنُّ أَن يُفۡعَلَ بِهَا فَاقِرَةٞ","transliteration":"Tathunnu an yufAAala biha faqiratun","translation":"","notes":""},{"id":26,"ref":"75:26","arabic":"كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِيَ","transliteration":"Kalla itha balaghati alttaraqiya","translation":"","notes":""},{"id":27,"ref":"75:27","arabic":"وَقِيلَ مَنۡۜ رَاقٖ","transliteration":"Waqeela man raqin","translation":"","notes":""},{"id":28,"ref":"75:28","arabic":"وَظَنَّ أَنَّهُ ٱلۡفِرَاقُ","transliteration":"Wathanna annahu alfiraqu","translation":"","notes":""},{"id":29,"ref":"75:29","arabic":"وَٱلۡتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ","transliteration":"Wailtaffati alssaqu bialssaqi","translation":"","notes":""},{"id":30,"ref":"75:30","arabic":"إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمَسَاقُ","transliteration":"Ila rabbika yawmaithin almasaqu","translation":"","notes":""},{"id":31,"ref":"75:31","arabic":"فَلَا صَدَّقَ وَلَا صَلَّىٰ","transliteration":"Fala saddaqa wala salla","translation":"","notes":""},{"id":32,"ref":"75:32","arabic":"وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ","transliteration":"Walakin kaththaba watawalla","translation":"","notes":""},{"id":33,"ref":"75:33","arabic":"ثُمَّ ذَهَبَ إِلَىٰٓ أَهۡلِهِۦ يَتَمَطَّىٰٓ","transliteration":"Thumma thahaba ila ahlihi yatamatta","translation":"","notes":""},{"id":34,"ref":"75:34","arabic":"أَوۡلَىٰ لَكَ فَأَوۡلَىٰ","transliteration":"Awla laka faawla","translation":"","notes":""},{"id":35,"ref":"75:35","arabic":"ثُمَّ أَوۡلَىٰ لَكَ فَأَوۡلَىٰٓ","transliteration":"Thumma awla laka faawla","translation":"","notes":""},{"id":36,"ref":"75:36","arabic":"أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَن يُتۡرَكَ سُدًى","transliteration":"Ayahsabu alinsanu an yutraka sudan","translation":"","notes":""},{"id":37,"ref":"75:37","arabic":"أَلَمۡ يَكُ نُطۡفَةٗ مِّن مَّنِيّٖ يُمۡنَىٰ","transliteration":"Alam yaku nutfatan min manayyin yumna","translation":"","notes":""},{"id":38,"ref":"75:38","arabic":"ثُمَّ كَانَ عَلَقَةٗ فَخَلَقَ فَسَوَّىٰ","transliteration":"Thumma kana AAalaqatan fakhalaqa fasawwa","translation":"","notes":""},{"id":39,"ref":"75:39","arabic":"فَجَعَلَ مِنۡهُ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ","transliteration":"FajaAAala minhu alzzawjayni alththakara waalontha","translation":"","notes":""},{"id":40,"ref":"75:40","arabic":"أَلَيۡسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحۡـِۧيَ ٱلۡمَوۡتَىٰ","