[{"id":1,"ref":"70:1","arabic":"سَأَلَ سَآئِلُۢ بِعَذَابٖ وَاقِعٖ","transliteration":"Saala sailun biAAathabin waqiAAin","translation":"","notes":""},{"id":2,"ref":"70:2","arabic":"لِّلۡكَٰفِرِينَ لَيۡسَ لَهُۥ دَافِعٞ","transliteration":"Lilkafireena laysa lahu dafiAAun","translation":"","notes":""},{"id":3,"ref":"70:3","arabic":"مِّنَ ٱللَّهِ ذِي ٱلۡمَعَارِجِ","transliteration":"Mina Allahi thee almaAAariji","translation":"","notes":""},{"id":4,"ref":"70:4","arabic":"تَعۡرُجُ ٱلۡمَلَـٰٓئِكَةُ وَٱلرُّوحُ إِلَيۡهِ فِي يَوۡمٖ كَانَ مِقۡدَارُهُۥ خَمۡسِينَ أَلۡفَ سَنَةٖ","transliteration":"TaAAruju almalaikatu waalrroohu ilayhi fee yawmin kana miqdaruhu khamseena alfa sanatin","translation":"","notes":""},{"id":5,"ref":"70:5","arabic":"فَٱصۡبِرۡ صَبۡرٗا جَمِيلًا","transliteration":"Faisbir sabran jameelan","translation":"","notes":""},{"id":6,"ref":"70:6","arabic":"إِنَّهُمۡ يَرَوۡنَهُۥ بَعِيدٗا","transliteration":"Innahum yarawnahu baAAeedan","translation":"","notes":""},{"id":7,"ref":"70:7","arabic":"وَنَرَىٰهُ قَرِيبٗا","transliteration":"Wanarahu qareeban","translation":"","notes":""},{"id":8,"ref":"70:8","arabic":"يَوۡمَ تَكُونُ ٱلسَّمَآءُ كَٱلۡمُهۡلِ","transliteration":"Yawma takoonu alssamao kaalmuhli","translation":"","notes":""},{"id":9,"ref":"70:9","arabic":"وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ","transliteration":"Watakoonu aljibalu kaalAAihni","translation":"","notes":""},{"id":10,"ref":"70:10","arabic":"وَلَا يَسۡـَٔلُ حَمِيمٌ حَمِيمٗا","transliteration":"Wala yasalu hameemun hameeman","translation":"","notes":""},{"id":11,"ref":"70:11","arabic":"يُبَصَّرُونَهُمۡۚ يَوَدُّ ٱلۡمُجۡرِمُ لَوۡ يَفۡتَدِي مِنۡ عَذَابِ يَوۡمِئِذِۭ بِبَنِيهِ","transliteration":"Yubassaroonahum yawaddu almujrimu law yaftadee min AAathabi yawmiithin bibaneehi","translation":"","notes":""},{"id":12,"ref":"70:12","arabic":"وَصَٰحِبَتِهِۦ وَأَخِيهِ","transliteration":"Wasahibatihi waakheehi","translation":"","notes":""},{"id":13,"ref":"70:13","arabic":"وَفَصِيلَتِهِ ٱلَّتِي تُـٔۡوِيهِ","transliteration":"Wafaseelatihi allatee tuweehi","translation":"","notes":""},{"id":14,"ref":"70:14","arabic":"وَمَن فِي ٱلۡأَرۡضِ جَمِيعٗا ثُمَّ يُنجِيهِ","transliteration":"Waman fee alardi jameeAAan thumma yunjeehi","translation":"","notes":""},{"id":15,"ref":"70:15","arabic":"كَلَّآۖ إِنَّهَا لَظَىٰ","transliteration":"Kalla innaha latha","translation":"","notes":""},{"id":16,"ref":"70:16","arabic":"نَزَّاعَةٗ لِّلشَّوَىٰ","transliteration":"NazzaAAatan lilshshawa","translation":"","notes":""},{"id":17,"ref":"70:17","arabic":"تَدۡعُواْ مَنۡ أَدۡبَرَ وَتَوَلَّىٰ","transliteration":"TadAAoo man adbara watawalla","translation":"","notes":""},{"id":18,"ref":"70:18","arabic":"وَجَمَعَ فَأَوۡعَىٰٓ","transliteration":"WajamaAAa faawAAa","translation":"","notes":""},{"id":19,"ref":"70:19","arabic":"۞إِنَّ ٱلۡإِنسَٰنَ خُلِقَ هَلُوعًا","transliteration":"Inna alinsana khuliqa halooAAan","translation":"","notes":""},{"id":20,"ref":"70:20","arabic":"إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعٗا","transliteration":"Itha massahu alshsharru jazooAAan","translation":"","notes":""},{"id":21,"ref":"70:21","arabic":"وَإِذَا مَسَّهُ ٱلۡخَيۡرُ مَنُوعًا","transliteration":"Waitha massahu alkhayru manooAAan","translation":"","notes":""},{"id":22,"ref":"70:22","arabic":"إِلَّا ٱلۡمُصَلِّينَ","transliteration":"Illa almusalleena","translation":"","notes":""},{"id":23,"ref":"70:23","arabic":"ٱلَّذِينَ هُمۡ عَلَىٰ صَلَاتِهِمۡ دَآئِمُونَ","transliteration":"Allatheena hum AAala salatihim daimoona","translation":"","notes":""},{"id":24,"ref":"70:24","arabic":"وَٱلَّذِينَ فِيٓ أَمۡوَٰلِهِمۡ حَقّٞ مَّعۡلُومٞ","transliteration":"Waallatheena fee amwalihim haqqun maAAloomun","translation":"","notes":""},{"id":25,"ref":"70:25","arabic":"لِّلسَّآئِلِ وَٱلۡمَحۡرُومِ","transliteration":"Lilssaili waalmahroomi","translation":"","notes":""},{"id":26,"ref":"70:26","arabic":"وَٱلَّذِينَ يُصَدِّقُونَ بِيَوۡمِ ٱلدِّينِ","transliteration":"Waallatheena yusaddiqoona biyawmi alddeeni","translation":"","notes":""},{"id":27,"ref":"70:27","arabic":"وَٱلَّذِينَ هُم مِّنۡ عَذَابِ رَبِّهِم مُّشۡفِقُونَ","transliteration":"Waallatheena hum min AAathabi rabbihim mushfiqoona","translation":"","notes":""},{"id":28,"ref":"70:28","arabic":"إِنَّ عَذَابَ رَبِّهِمۡ غَيۡرُ مَأۡمُونٖ","transliteration":"Inna AAathaba rabbihim ghayru mamoonin","translation":"","notes":""},{"id":29,"ref":"70:29","arabic":"وَٱلَّذِينَ هُمۡ لِفُرُوجِهِمۡ حَٰفِظُونَ","transliteration":"Waallatheena hum lifuroojihim hafithoona","translation":"","notes":""},{"id":30,"ref":"70:30","arabic":"إِلَّا عَلَىٰٓ أَزۡوَٰجِهِمۡ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمۡ فَإِنَّهُمۡ غَيۡرُ مَلُومِينَ","transliteration":"Illa AAala azwajihim aw ma malakat aymanuhum fainnahum ghayru maloomeena","translation":"","notes":""},{"id":31,"ref":"70:31","arabic":"فَمَنِ ٱبۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَـٰٓئِكَ هُمُ ٱلۡعَادُونَ","transliteration":"Famani ibtagha waraa thalika faolaika humu alAAadoona","translation":"","notes":""},{"id":32,"ref":"70:32","arabic":"وَٱلَّذِينَ هُمۡ لِأَمَٰنَٰتِهِمۡ وَعَهۡدِهِمۡ رَٰعُونَ","transliteration":"Waallatheena hum liamanatihim waAAahdihim raAAoona","translation":"","notes":""},{"id":33,"ref":"70:33","arabic":"وَٱلَّذِينَ هُم بِشَهَٰدَٰتِهِمۡ قَآئِمُونَ","transliteration":"Waallatheena hum bishahadatihim qaimoona","translation":"","notes":""},{"id":34,"ref":"70:34","arabic":"وَٱلَّذِينَ هُمۡ عَلَىٰ صَلَاتِهِمۡ يُحَافِظُونَ","transliteration":"Waallatheena hum AAala salatihim yuhafithoona","translation":"","notes":""},{"id":35,"ref":"70:35","arabic":"أُوْلَـٰٓئِكَ فِي جَنَّـٰتٖ مُّكۡرَمُونَ","transliteration":"Olaika fee jannatin mukramoona","translation":"","notes":""},{"id":36,"ref":"70:36","arabic":"فَمَالِ ٱلَّذِينَ كَفَرُواْ قِبَلَكَ مُهۡطِعِينَ","transliteration":"Famali allatheena kafaroo qibalaka muhtiAAeena","translation":"","notes":""},{"id":37,"ref":"70:37","arabic":"عَنِ ٱلۡيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ","transliteration":"AAani alyameeni waAAani alshshimali AAizeena","translation":"","notes":""},{"id":38,"ref":"70:38","arabic":"أَيَطۡمَعُ كُلُّ ٱمۡرِيٕٖ مِّنۡهُمۡ أَن يُدۡخَلَ جَنَّةَ نَعِيمٖ","transliteration":"AyatmaAAu kullu imriin minhum an yudkhala jannata naAAeemin","translation":"","notes":""},{"id":39,"ref":"70:39","arabic":"كَلَّآۖ إِنَّا خَلَقۡنَٰهُم مِّمَّا يَعۡلَمُونَ","transliteration":"Kalla inna khalaqnahum mimma yaAAlamoona","translation":"","notes":""},{"id":40,"ref":"70:40","arabic":"فَلَآ أُقۡسِمُ بِرَبِّ ٱلۡمَشَٰرِقِ وَٱلۡمَغَٰرِبِ إِنَّا لَقَٰدِرُونَ","transliteration":"Fala oqsimu birabbi almashariqi waalmagharibi inna laqadiroona","translation":"","notes":""},{"id":41,"ref":"70:41","arabic":"عَلَىٰٓ أَن نُّبَدِّلَ خَيۡرٗا مِّنۡهُمۡ وَمَا نَحۡنُ بِمَسۡبُوقِينَ","transliteration":"AAala an nubaddila khayran minhum wama nahnu bimasbooqeena","translation":"","notes":""},{"id":42,"ref":"70:42","arabic":"فَذَرۡهُمۡ يَخُوضُواْ وَيَلۡعَبُواْ حَتَّىٰ يُلَٰقُواْ يَوۡمَهُمُ ٱلَّذِي يُوعَدُونَ","transliteration":"Fatharhum yakhoodoo wayalAAaboo hatta yulaqoo yawmahumu allathee yooAAadoona","translation":"","notes":""},{"id":43,"ref":"70:43","arabic":"يَوۡمَ يَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ سِرَاعٗا كَأَنَّهُمۡ إِلَىٰ نُصُبٖ يُوفِضُونَ","transliteration":"Yawma yakhrujoona mina alajdathi siraAAan kaannahum ila nusubin yoofidoona","translation":"","notes":""},{"id":44,"ref":"70:44","arabic":"خَٰشِعَةً أَبۡصَٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةٞۚ ذَٰلِكَ ٱلۡيَوۡمُ ٱلَّذِي كَانُواْ يُوعَدُونَ","transliteration":"KhashiAAatan absaruhum tarhaquhum thillatun thalika alyawmu allathee kanoo yooAAadoona","translation":"","notes":""}]