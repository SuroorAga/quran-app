[{"id":1,"ref":"96:1","arabic":"ٱقۡرَأۡ بِٱسۡمِ رَبِّكَ ٱلَّذِي خَلَقَ","transliteration":"Iqra biismi rabbika allathee khalaqa","translation":"","notes":""},{"id":2,"ref":"96:2","arabic":"خَلَقَ ٱلۡإِنسَٰنَ مِنۡ عَلَقٍ","transliteration":"Khalaqa alinsana min AAalaqin","translation":"","notes":""},{"id":3,"ref":"96:3","arabic":"ٱقۡرَأۡ وَرَبُّكَ ٱلۡأَكۡرَمُ","transliteration":"Iqra warabbuka alakramu","translation":"","notes":""},{"id":4,"ref":"96:4","arabic":"ٱلَّذِي عَلَّمَ بِٱلۡقَلَمِ","transliteration":"Allathee AAallama bialqalami","translation":"","notes":""},{"id":5,"ref":"96:5","arabic":"عَلَّمَ ٱلۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ","transliteration":"AAallama alinsana ma lam yaAAlam","translation":"","notes":""},{"id":6,"ref":"96:6","arabic":"كَلَّآ إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰٓ","transliteration":"Kalla inna alinsana layatgha","translation":"","notes":""},{"id":7,"ref":"96:7","arabic":"أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ","transliteration":"An raahu istaghna","translation":"","notes":""},{"id":8,"ref":"96:8","arabic":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجۡعَىٰٓ","transliteration":"Inna ila rabbika alrrujAAa","translation":"","notes":""},{"id":9,"ref":"96:9","arabic":"أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ","transliteration":"Araayta allathee yanha","translation":"","notes":""},{"id":10,"ref":"96:10","arabic":"عَبۡدًا إِذَا صَلَّىٰٓ","transliteration":"AAabdan itha salla","translation":"","notes":""},{"id":11,"ref":"96:11","arabic":"أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ","transliteration":"Araayta in kana AAala alhuda","translation":"","notes":""},{"id":12,"ref":"96:12","arabic":"أَوۡ أَمَرَ بِٱلتَّقۡوَىٰٓ","transliteration":"Aw amara bialttaqwa","translation":"","notes":""},{"id":13,"ref":"96:13","arabic":"أَرَءَيۡتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","transliteration":"Araayta in kaththaba watawalla","translation":"","notes":""},{"id":14,"ref":"96:14","arabic":"أَلَمۡ يَعۡلَم بِأَنَّ ٱللَّهَ يَرَىٰ","transliteration":"Alam yaAAlam bianna Allaha yara","translation":"","notes":""},{"id":15,"ref":"96:15","arabic":"كَلَّا لَئِن لَّمۡ يَنتَهِ لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ","transliteration":"Kalla lain lam yantahi lanasfaAAan bialnnasiyati","translation":"","notes":""},{"id":16,"ref":"96:16","arabic":"نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖ","transliteration":"Nasiyatin kathibatin khatiatin","translation":"","notes":""},{"id":17,"ref":"96:17","arabic":"فَلۡيَدۡعُ نَادِيَهُۥ","transliteration":"FalyadAAu nadiyahu","translation":"","notes":""},{"id":18,"ref":"96:18","arabic":"سَنَدۡعُ ٱلزَّبَانِيَةَ","transliteration":"SanadAAu alzzabaniyata","translation":"","notes":""},{"id":19,"ref":"96:19","arabic":"كَلَّا لَا تُطِعۡهُ وَٱسۡجُدۡۤ وَٱقۡتَرِب۩","transliteration":"Kalla la tutiAAhu waosjud waiqtarib","translation":"","notes":""}]