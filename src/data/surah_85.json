[{"id":1,"ref":"85:1","arabic":"وَٱلسَّمَآءِ ذَاتِ ٱلۡبُرُوجِ","transliteration":"Waalssamai thati alburooji","translation":"","notes":""},{"id":2,"ref":"85:2","arabic":"وَٱلۡيَوۡمِ ٱلۡمَوۡعُودِ","transliteration":"Waalyawmi almawAAoodi","translation":"","notes":""},{"id":3,"ref":"85:3","arabic":"وَشَاهِدٖ وَمَشۡهُودٖ","transliteration":"Washahidin wamashhoodin","translation":"","notes":""},{"id":4,"ref":"85:4","arabic":"قُتِلَ أَصۡحَٰبُ ٱلۡأُخۡدُودِ","transliteration":"Qutila ashabu alukhdoodi","translation":"","notes":""},{"id":5,"ref":"85:5","arabic":"ٱلنَّارِ ذَاتِ ٱلۡوَقُودِ","transliteration":"Alnnari thati alwaqoodi","translation":"","notes":""},{"id":6,"ref":"85:6","arabic":"إِذۡ هُمۡ عَلَيۡهَا قُعُودٞ","transliteration":"Ith hum AAalayha quAAoodun","translation":"","notes":""},{"id":7,"ref":"85:7","arabic":"وَهُمۡ عَلَىٰ مَا يَفۡعَلُونَ بِٱلۡمُؤۡمِنِينَ شُهُودٞ","transliteration":"Wahum AAala ma yafAAaloona bialmumineena shuhoodun","translation":"","notes":""},{"id":8,"ref":"85:8","arabic":"وَمَا نَقَمُواْ مِنۡهُمۡ إِلَّآ أَن يُؤۡمِنُواْ بِٱللَّهِ ٱلۡعَزِيزِ ٱلۡحَمِيدِ","transliteration":"Wama naqamoo minhum illa an yuminoo biAllahi alAAazeezi alhameedi","translation":"","notes":""},{"id":9,"ref":"85:9","arabic":"ٱلَّذِي لَهُۥ مُلۡكُ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ وَٱللَّهُ عَلَىٰ كُلِّ شَيۡءٖ شَهِيدٌ","transliteration":"Allathee lahu mulku alssamawati waalardi waAllahu AAala kulli shayin shaheedun","translation":"","notes":""},{"id":10,"ref":"85:10","arabic":"إِنَّ ٱلَّذِينَ فَتَنُواْ ٱلۡمُؤۡمِنِينَ وَٱلۡمُؤۡمِنَٰتِ ثُمَّ لَمۡ يَتُوبُواْ فَلَهُمۡ عَذَابُ جَهَنَّمَ وَلَهُمۡ عَذَابُ ٱلۡحَرِيقِ","transliteration":"Inna allatheena fatanoo almumineena waalmuminati thumma lam yatooboo falahum AAathabu jahannama walahum AAathabu alhareeqi","translation":"","notes":""},{"id":11,"ref":"85:11","arabic":"إِنَّ ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّـٰلِحَٰتِ لَهُمۡ جَنَّـٰتٞ تَجۡرِي مِن تَحۡتِهَا ٱلۡأَنۡهَٰرُۚ ذَٰلِكَ ٱلۡفَوۡزُ ٱلۡكَبِيرُ","transliteration":"Inna allatheena amanoo waAAamiloo alssalihati lahum jannatun tajree min tahtiha alanharu thalika alfawzu alkabeeru","translation":"","notes":""},{"id":12,"ref":"85:12","arabic":"إِنَّ بَطۡشَ رَبِّكَ لَشَدِيدٌ","transliteration":"Inna batsha rabbika lashadeedun","translation":"","notes":""},{"id":13,"ref":"85:13","arabic":"إِنَّهُۥ هُوَ يُبۡدِئُ وَيُعِيدُ","transliteration":"Innahu huwa yubdio wayuAAeedu","translation":"","notes":""},{"id":14,"ref":"85:14","arabic":"وَهُوَ ٱلۡغَفُورُ ٱلۡوَدُودُ","transliteration":"Wahuwa alghafooru alwadoodu","translation":"","notes":""},{"id":15,"ref":"85:15","arabic":"ذُو ٱلۡعَرۡشِ ٱلۡمَجِيدُ","transliteration":"Thoo alAAarshi almajeedi","translation":"","notes":""},{"id":16,"ref":"85:16","arabic":"فَعَّالٞ لِّمَا يُرِيدُ","transliteration":"FaAAAAalun lima yureedu","translation":"","notes":""},{"id":17,"ref":"85:17","arabic":"هَلۡ أَتَىٰكَ حَدِيثُ ٱلۡجُنُودِ","transliteration":"Hal ataka hadeethu aljunoodi","translation":"","notes":""},{"id":18,"ref":"85:18","arabic":"فِرۡعَوۡنَ وَثَمُودَ","transliteration":"FirAAawna wathamooda","translation":"","notes":""},{"id":19,"ref":"85:19","arabic":"بَلِ ٱلَّذِينَ كَفَرُواْ فِي تَكۡذِيبٖ","transliteration":"Bali allatheena kafaroo fee taktheebin","translation":"","notes":""},{"id":20,"ref":"85:20","arabic":"وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطُۢ","transliteration":"WaAllahu min waraihim muheetun","translation":"","notes":""},{"id":21,"ref":"85:21","arabic":"بَلۡ هُوَ قُرۡءَانٞ مَّجِيدٞ","transliteration":"Bal huwa quranun majeedun","translation":"","notes":""},{"id":22,"ref":"85:22","arabic":"فِي لَوۡحٖ مَّحۡفُوظِۭ","transliteration":"Fee lawhin mahfoothin","translation":"","notes":""}]