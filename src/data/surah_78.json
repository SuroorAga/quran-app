[{"id":1,"ref":"78:1","arabic":"عَمَّ يَتَسَآءَلُونَ","transliteration":"AAamma yatasaaloona","translation":"","notes":""},{"id":2,"ref":"78:2","arabic":"عَنِ ٱلنَّبَإِ ٱلۡعَظِيمِ","transliteration":"AAani alnnabai alAAatheemi","translation":"","notes":""},{"id":3,"ref":"78:3","arabic":"ٱلَّذِي هُمۡ فِيهِ مُخۡتَلِفُونَ","transliteration":"Allathee hum feehi mukhtalifoona","translation":"","notes":""},{"id":4,"ref":"78:4","arabic":"كَلَّا سَيَعۡلَمُونَ","transliteration":"Kalla sayaAAlamoona","translation":"","notes":""},{"id":5,"ref":"78:5","arabic":"ثُمَّ كَلَّا سَيَعۡلَمُونَ","transliteration":"Thumma kalla sayaAAlamoona","translation":"","notes":""},{"id":6,"ref":"78:6","arabic":"أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ مِهَٰدٗا","transliteration":"Alam najAAali alarda mihadan","translation":"","notes":""},{"id":7,"ref":"78:7","arabic":"وَٱلۡجِبَالَ أَوۡتَادٗا","transliteration":"Waaljibala awtadan","translation":"","notes":""},{"id":8,"ref":"78:8","arabic":"وَخَلَقۡنَٰكُمۡ أَزۡوَٰجٗا","transliteration":"Wakhalaqnakum azwajan","translation":"","notes":""},{"id":9,"ref":"78:9","arabic":"وَجَعَلۡنَا نَوۡمَكُمۡ سُبَاتٗا","transliteration":"WajaAAalna nawmakum subatan","translation":"","notes":""},{"id":10,"ref":"78:10","arabic":"وَجَعَلۡنَا ٱلَّيۡلَ لِبَاسٗا","transliteration":"WajaAAalna allayla libasan","translation":"","notes":""},{"id":11,"ref":"78:11","arabic":"وَجَعَلۡنَا ٱلنَّهَارَ مَعَاشٗا","transliteration":"WajaAAalna alnnahara maAAashan","translation":"","notes":""},{"id":12,"ref":"78:12","arabic":"وَبَنَيۡنَا فَوۡقَكُمۡ سَبۡعٗا شِدَادٗا","transliteration":"Wabanayna fawqakum sabAAan shidadan","translation":"","notes":""},{"id":13,"ref":"78:13","arabic":"وَجَعَلۡنَا سِرَاجٗا وَهَّاجٗا","transliteration":"WajaAAalna sirajan wahhajan","translation":"","notes":""},{"id":14,"ref":"78:14","arabic":"وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَٰتِ مَآءٗ ثَجَّاجٗا","transliteration":"Waanzalna mina almuAAsirati maan thajjajan","translation":"","notes":""},{"id":15,"ref":"78:15","arabic":"لِّنُخۡرِجَ بِهِۦ حَبّٗا وَنَبَاتٗا","transliteration":"Linukhrija bihi habban wanabatan","translation":"","notes":""},{"id":16,"ref":"78:16","arabic":"وَجَنَّـٰتٍ أَلۡفَافًا","transliteration":"Wajannatin alfafan","translation":"","notes":""},{"id":17,"ref":"78:17","arabic":"إِنَّ يَوۡمَ ٱلۡفَصۡلِ كَانَ مِيقَٰتٗا","transliteration":"Inna yawma alfasli kana meeqatan","translation":"","notes":""},{"id":18,"ref":"78:18","arabic":"يَوۡمَ يُنفَخُ فِي ٱلصُّورِ فَتَأۡتُونَ أَفۡوَاجٗا","transliteration":"Yawma yunfakhu fee alssoori fatatoona afwajan","translation":"","notes":""},{"id":19,"ref":"78:19","arabic":"وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتۡ أَبۡوَٰبٗا","transliteration":"Wafutihati alssamao fakanat abwaban","translation":"","notes":""},{"id":20,"ref":"78:20","arabic":"وَسُيِّرَتِ ٱلۡجِبَالُ فَكَانَتۡ سَرَابًا","transliteration":"Wasuyyirati aljibalu fakanat saraban","translation":"","notes":""},{"id":21,"ref":"78:21","arabic":"إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادٗا","transliteration":"Inna jahannama kanat mirsadan","translation":"","notes":""},{"id":22,"ref":"78:22","arabic":"لِّلطَّـٰغِينَ مَـَٔابٗا","transliteration":"Lilttagheena maaban","translation":"","notes":""},{"id":23,"ref":"78:23","arabic":"لَّـٰبِثِينَ فِيهَآ أَحۡقَابٗا","transliteration":"Labitheena feeha ahqaban","translation":"","notes":""},{"id":24,"ref":"78:24","arabic":"لَّا يَذُوقُونَ فِيهَا بَرۡدٗا وَلَا شَرَابًا","transliteration":"La yathooqoona feeha bardan wala sharaban","translation":"","notes":""},{"id":25,"ref":"78:25","arabic":"إِلَّا حَمِيمٗا وَغَسَّاقٗا","transliteration":"Illa hameeman waghassaqan","translation":"","notes":""},{"id":26,"ref":"78:26","arabic":"جَزَآءٗ وِفَاقًا","transliteration":"Jazaan wifaqan","translation":"","notes":""},{"id":27,"ref":"78:27","arabic":"إِنَّهُمۡ كَانُواْ لَا يَرۡجُونَ حِسَابٗا","transliteration":"Innahum kanoo la yarjoona hisaban","translation":"","notes":""},{"id":28,"ref":"78:28","arabic":"وَكَذَّبُواْ بِـَٔايَٰتِنَا كِذَّابٗا","transliteration":"Wakaththaboo biayatina kiththaban","translation":"","notes":""},{"id":29,"ref":"78:29","arabic":"وَكُلَّ شَيۡءٍ أَحۡصَيۡنَٰهُ كِتَٰبٗا","transliteration":"Wakulla shayin ahsaynahu kitaban","translation":"","notes":""},{"id":30,"ref":"78:30","arabic":"فَذُوقُواْ فَلَن نَّزِيدَكُمۡ إِلَّا عَذَابًا","transliteration":"Fathooqoo falan nazeedakum illa AAathaban","translation":"","notes":""},{"id":31,"ref":"78:31","arabic":"إِنَّ لِلۡمُتَّقِينَ مَفَازًا","transliteration":"Inna lilmuttaqeena mafazan","translation":"","notes":""},{"id":32,"ref":"78:32","arabic":"حَدَآئِقَ وَأَعۡنَٰبٗا","transliteration":"Hadaiqa waaAAnaban","translation":"","notes":""},{"id":33,"ref":"78:33","arabic":"وَكَوَاعِبَ أَتۡرَابٗا","transliteration":"WakawaAAiba atraban","translation":"","notes":""},{"id":34,"ref":"78:34","arabic":"وَكَأۡسٗا دِهَاقٗا","transliteration":"Wakasan dihaqan","translation":"","notes":""},{"id":35,"ref":"78:35","arabic":"لَّا يَسۡمَعُونَ فِيهَا لَغۡوٗا وَلَا كِذَّـٰبٗا","transliteration":"La yasmaAAoona feeha laghwan wala kiththaban","translation":"","notes":""},{"id":36,"ref":"78:36","arabic":"جَزَآءٗ مِّن رَّبِّكَ عَطَآءً حِسَابٗا","transliteration":"Jazaan min rabbika AAataan hisaban","translation":"","notes":""},{"id":37,"ref":"78:37","arabic":"رَّبِّ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ وَمَا بَيۡنَهُمَا ٱلرَّحۡمَٰنِۖ لَا يَمۡلِكُونَ مِنۡهُ خِطَابٗا","transliteration":"Rabbi alssamawati waalardi wama baynahuma alrrahmani la yamlikoona minhu khitaban","translation":"","notes":""},{"id":38,"ref":"78:38","arabic":"يَوۡمَ يَقُومُ ٱلرُّوحُ وَٱلۡمَلَـٰٓئِكَةُ صَفّٗاۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَٰنُ وَقَالَ صَوَابٗا","transliteration":"Yawma yaqoomu alrroohu waalmalaikatu saffan la yatakallamoona illa man athina lahu alrrahmanu waqala sawaban","translation":"","notes":""},{"id":39,"ref":"78:39","arabic":"ذَٰلِكَ ٱلۡيَوۡمُ ٱلۡحَقُّۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا","transliteration":"Thalika alyawmu alhaqqu faman shaa ittakhatha ila rabbihi maaban","translation":"","notes":""},{"id":40,"ref":"78:40","arabic":"إِنَّآ أَنذَرۡنَٰكُمۡ عَذَابٗا قَرِيبٗا يَوۡمَ يَنظُرُ ٱلۡمَرۡءُ مَا قَدَّمَتۡ يَدَاهُ وَيَقُولُ ٱلۡكَافِرُ يَٰلَيۡتَنِي كُنتُ تُرَٰبَۢا","transliteration":"Inna antharnakum AAathaban qareeban yawma yanthuru almaro ma qaddamat yadahu wayaqoolu alkafiru ya laytanee kuntu turaban","translation":"","notes":""}]